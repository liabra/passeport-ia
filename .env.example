# Passeport IA — variables d'environnement
#
# La v1 est volontairement « zéro-donnée » : aucune base de données, aucun
# compte, aucun tracker. Il n'y a donc AUCUN secret requis pour faire tourner
# l'application. Ce fichier est un gabarit ; ne mettez jamais de secret réel
# dans le dépôt.

# Port d'écoute en production (Railway le fournit automatiquement).
# PORT=3000

# Origine publique de l'application (utile plus tard, ex. balises canoniques).
# NEXT_PUBLIC_SITE_URL=https://passeport-ia.example
